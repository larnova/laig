# ─────────────────────────────────────────────────────────────
# LAIG environment variables — copy to `.env.local` and fill in.
# All are OPTIONAL for local dev; the app degrades gracefully.
# Set the production values in the Netlify dashboard (Site settings →
# Environment variables), not in a committed file.
# ─────────────────────────────────────────────────────────────

# Magic-link email (Resend — https://resend.com).
# Without RESEND_API_KEY, sign-in links are logged to the server console
# instead of emailed. REQUIRED in production for ambassadors/admins to log in.
RESEND_API_KEY=
# Verified sender for the magic-link email. The domain must be verified in
# Resend. Defaults to "LAIG <noreply@larnova.co>" if unset.
EMAIL_FROM="LAIG <noreply@larnova.co>"

# Comma-separated list of LAIG HQ admin emails (can post org-wide events).
# Any address ending in "@larnova.co" is always treated as an admin.
# Defaults to "admin@runbeta.io" if unset.
LAIG_ADMIN_EMAILS=admin@runbeta.io

# Canonical site origin used to build magic-link URLs, e.g.
# https://laig.larnova.co . If unset, it is derived from the request host
# (works on Netlify and on localhost automatically).
SITE_URL=

# Netlify Blobs (the data store) needs no config on Netlify or under
# `netlify dev` — credentials are injected automatically. Under a plain
# `next dev` the app falls back to a local JSON store in `.laig-data/`.
